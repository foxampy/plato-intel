# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=

# Bot name
BOT_NAME=PlatoIntelBot

# Webhook URL (for production)
WEBHOOK_URL=

# Qwen AI Configuration (DashScope)
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-max
QWEN_TEMPERATURE=0.7
QWEN_MAX_TOKENS=500

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/plato_bot

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=

# Payment Configuration
PAYMENT_PROVIDER_TOKEN=

# Delivery Configuration
DELIVERY_MIN_FREE=500
DELIVERY_BASE_PRICE=15

# Discount Configuration
DISCOUNT_LEVEL_1=500
DISCOUNT_LEVEL_1_PERCENT=3
DISCOUNT_LEVEL_2=1000
DISCOUNT_LEVEL_2_PERCENT=5
DISCOUNT_LEVEL_3=3000
DISCOUNT_LEVEL_3_PERCENT=7
DISCOUNT_LEVEL_4=5000
DISCOUNT_LEVEL_4_PERCENT=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# Environment
ENVIRONMENT=development
